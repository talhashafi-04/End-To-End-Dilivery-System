<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx" 
            xmlns:fx="http://javafx.com/fxml" 
            fx:controller="application.ManagerDashboardController"
            style="-fx-background-color: #f5f7fa;">
    
    <!-- Top Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #28a745; -fx-padding: 15;">
            <Label text="👔 Manager Dashboard" 
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text="Welcome, Manager" 
                   style="-fx-text-fill: white; -fx-font-size: 14px;"/>
            <Button text="Refresh" onAction="#loadPendingOrders"
                    style="-fx-background-color: #218838; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
            <Button text="Logout" onAction="#handleLogout" 
                    style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
        </HBox>
    </top>
    
    <!-- Main Content -->
    <center>
        <VBox spacing="20" style="-fx-padding: 30;">
            
            <!-- Stats Cards -->
            <HBox spacing="20">
                <VBox spacing="5" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-min-width: 200;">
                    <effect>
                        <javafx.scene.effect.DropShadow color="#00000020" radius="10" offsetY="3"/>
                    </effect>
                    <Label text="📦 Pending Requests" style="-fx-font-size: 14px; -fx-text-fill: #666;"/>
                    <Label fx:id="pendingCountLabel" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #ffc107;"/>
                </VBox>
                
                <VBox spacing="5" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-min-width: 200;">
                    <effect>
                        <javafx.scene.effect.DropShadow color="#00000020" radius="10" offsetY="3"/>
                    </effect>
                    <Label text="✅ Approved Today" style="-fx-font-size: 14px; -fx-text-fill: #666;"/>
                    <Label fx:id="approvedCountLabel" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #28a745;"/>
                </VBox>
                
                <VBox spacing="5" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-min-width: 200;">
                    <effect>
                        <javafx.scene.effect.DropShadow color="#00000020" radius="10" offsetY="3"/>
                    </effect>
                    <Label text="❌ Rejected Today" style="-fx-font-size: 14px; -fx-text-fill: #666;"/>
                    <Label fx:id="rejectedCountLabel" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #dc3545;"/>
                </VBox>
            </HBox>
            
            <!-- Pending Orders Section -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 30;" VBox.vgrow="ALWAYS">
                <effect>
                    <javafx.scene.effect.DropShadow color="#00000020" radius="15" offsetY="5"/>
                </effect>
                
                <Label text="📋 Pending Delivery Requests" 
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                
                <Separator/>
                
                <!-- Orders List -->
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <VBox fx:id="ordersContainer" spacing="15" style="-fx-padding: 10;"/>
                </ScrollPane>
                
            </VBox>
            
        </VBox>
    </center>
    
</BorderPane>