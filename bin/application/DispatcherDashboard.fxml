<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx" 
            xmlns:fx="http://javafx.com/fxml" 
            fx:controller="application.DispatcherDashboardController"
            style="-fx-background-color: #f5f7fa;">
    
    <!-- Top Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #ff9800; -fx-padding: 15;">
            <Label text="🚦 Dispatcher Dashboard" 
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text="Welcome, Dispatcher" 
                   style="-fx-text-fill: white; -fx-font-size: 14px;"/>
            <Button text="Refresh" onAction="#loadApprovedOrders"
                    style="-fx-background-color: #f57c00; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
            <Button text="Logout" onAction="#handleLogout" 
                    style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
        </HBox>
    </top>
    
    <!-- Main Content -->
    <center>
        <VBox spacing="20" style="-fx-padding: 30;">
            
            <!-- Stats Cards -->
            <HBox spacing="20">
                <VBox spacing="5" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-min-width: 220;">
                    <effect>
                        <javafx.scene.effect.DropShadow color="#00000020" radius="10" offsetY="3"/>
                    </effect>
                    <Label text="📦 Approved Orders" style="-fx-font-size: 14px; -fx-text-fill: #666;"/>
                    <Label fx:id="approvedCountLabel" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #ff9800;"/>
                </VBox>
                
                <VBox spacing="5" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-min-width: 220;">
                    <effect>
                        <javafx.scene.effect.DropShadow color="#00000020" radius="10" offsetY="3"/>
                    </effect>
                    <Label text="🏍️ Available Riders" style="-fx-font-size: 14px; -fx-text-fill: #666;"/>
                    <Label fx:id="availableRidersLabel" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #28a745;"/>
                </VBox>
                
                <VBox spacing="5" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-min-width: 220;">
                    <effect>
                        <javafx.scene.effect.DropShadow color="#00000020" radius="10" offsetY="3"/>
                    </effect>
                    <Label text="✓ Assigned Today" style="-fx-font-size: 14px; -fx-text-fill: #666;"/>
                    <Label fx:id="assignedTodayLabel" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2196F3;"/>
                </VBox>
            </HBox>
            
            <!-- Approved Orders Section -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 30;" VBox.vgrow="ALWAYS">
                <effect>
                    <javafx.scene.effect.DropShadow color="#00000020" radius="15" offsetY="5"/>
                </effect>
                
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Label text="📋 Approved Orders - Assign Pickup Riders" 
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="ℹ️ Select an order to assign a pickup rider" 
                           style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                </HBox>
                
                <Separator/>
                
                <!-- Orders List -->
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <VBox fx:id="ordersContainer" spacing="15" style="-fx-padding: 10;"/>
                </ScrollPane>
                
            </VBox>
            
        </VBox>
    </center>
    
</BorderPane>