<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="application.SignupController"
            prefWidth="900" prefHeight="750"
            style="-fx-background-color: #f5f5f5;">
    
    <top>
        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="20" 
              style="-fx-background-color: linear-gradient(to right, #2980B9, #2C3E50); -fx-padding: 20 40;">
            <Label text="📦" style="-fx-font-size: 32px;"/>
            <VBox>
                <Label text="SwiftShip Registration" 
                       style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold; -fx-font-family: 'Century Gothic';"/>
                <Label text="Create your account and join our delivery network" 
                       style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12px;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Back to Login" onAction="#backToLogin"
                    style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 10 20; -fx-background-radius: 6;"/>
        </HBox>
    </top>
    
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox alignment="TOP_CENTER" spacing="25" style="-fx-padding: 40;">
                
                <!-- Main Form Card -->
                <VBox spacing="25" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 40; -fx-pref-width: 750;">
                    <effect><DropShadow color="#00000020" radius="15" offsetY="5"/></effect>
                    
                    <!-- Form Title -->
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Label text="📝" style="-fx-font-size: 28px;"/>
                        <VBox>
                            <Label text="Account Registration" 
                                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2C3E50; -fx-font-family: 'Century Gothic';"/>
                            <Label text="Fill in your details to create a new account" 
                                   style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                        </VBox>
                    </HBox>
                    
                    <Separator style="-fx-background-color: #ecf0f1;"/>
                    
                    <!-- Role Selection -->
                    <VBox spacing="10">
                        <Label text="Account Type *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                        <ComboBox fx:id="roleComboBox" prefWidth="670" prefHeight="40"
                                  onAction="#handleRoleChange"
                                  style="-fx-font-size: 13px; -fx-background-radius: 8; -fx-border-color: #dce0e3; -fx-border-radius: 8; -fx-border-width: 2;"/>
                        <Label text="Select the type of account you want to create" 
                               style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;"/>
                    </VBox>
                    
                    <Separator style="-fx-background-color: #ecf0f1;"/>
                    
                    <!-- Account Credentials -->
                    <Label text="🔐 Account Credentials" 
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2980B9;"/>
                    
                    <GridPane hgap="20" vgap="20">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>
                        
                        <!-- Username -->
                        <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Username *" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                            <TextField fx:id="usernameField" promptText="Choose a unique username"
                                       style="-fx-pref-height: 40; -fx-font-size: 13px; -fx-background-radius: 8; -fx-border-color: #dce0e3; -fx-border-radius: 8; -fx-border-width: 2;"/>
                        </VBox>
                        
                        <!-- Email -->
                        <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Email Address *" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                            <TextField fx:id="emailField" promptText="your.email@example.com"
                                       style="-fx-pref-height: 40; -fx-font-size: 13px; -fx-background-radius: 8; -fx-border-color: #dce0e3; -fx-border-radius: 8; -fx-border-width: 2;"/>
                        </VBox>
                        
                        <!-- Password -->
                        <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Password *" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                            <PasswordField fx:id="passwordField" promptText="Enter strong password"
                                           style="-fx-pref-height: 40; -fx-font-size: 13px; -fx-background-radius: 8; -fx-border-color: #dce0e3; -fx-border-radius: 8; -fx-border-width: 2;"/>
                        </VBox>
                        
                        <!-- Confirm Password -->
                        <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="Confirm Password *" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                            <PasswordField fx:id="confirmPasswordField" promptText="Re-enter password"
                                           style="-fx-pref-height: 40; -fx-font-size: 13px; -fx-background-radius: 8; -fx-border-color: #dce0e3; -fx-border-radius: 8; -fx-border-width: 2;"/>
                        </VBox>
                        
                        <!-- Phone -->
                        <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="2">
                            <Label text="Phone Number *" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                            <TextField fx:id="phoneField" promptText="03XX-XXXXXXX"
                                       style="-fx-pref-height: 40; -fx-font-size: 13px; -fx-background-radius: 8; -fx-border-color: #dce0e3; -fx-border-radius: 8; -fx-border-width: 2;"/>
                        </VBox>
                        
                        <!-- Additional field based on role -->
                        <VBox fx:id="additionalFieldContainer" spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="2">
                            <!-- Dynamic field will be added here -->
                        </VBox>
                    </GridPane>
                    
                    <!-- Address (For customers and riders) -->
                    <VBox fx:id="addressContainer" spacing="10">
                        <Label text="📍 Address Information" 
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2980B9;"/>
                        <VBox spacing="8">
                            <Label text="Complete Address *" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                            <TextArea fx:id="addressField" promptText="Enter your complete address (House #, Street, Area, City)"
                                      wrapText="true" prefRowCount="3"
                                      style="-fx-font-size: 13px; -fx-background-radius: 8; -fx-border-color: #dce0e3; -fx-border-radius: 8; -fx-border-width: 2;"/>
                        </VBox>
                    </VBox>
                    
                    <!-- Role-specific fields -->
                    <VBox fx:id="roleSpecificContainer" spacing="15">
                        <!-- Will be populated dynamically -->
                    </VBox>
                    
                    <Separator style="-fx-background-color: #ecf0f1;"/>
                    
                    <!-- Terms and Conditions -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <CheckBox fx:id="termsCheckbox" 
                                  style="-fx-font-size: 12px;"/>
                        <Label text="I agree to the Terms of Service and Privacy Policy" 
                               style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                    </HBox>
                    
                    <!-- Action Buttons -->
                    <HBox spacing="15" alignment="CENTER">
                        <Button text="Create Account" onAction="#handleSignup" prefWidth="200" prefHeight="45"
                                style="-fx-background-color: #2ECC71; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;">
                            <effect><DropShadow color="#2ECC7180" radius="10" offsetY="3"/></effect>
                        </Button>
                        
                        <Button text="Clear Form" onAction="#handleClear" prefWidth="150" prefHeight="45"
                                style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                    </HBox>
                    
                    <!-- Status Label -->
                    <Label fx:id="statusLabel" alignment="CENTER" wrapText="true"
                           style="-fx-font-size: 13px; -fx-padding: 12; -fx-background-radius: 6; -fx-pref-width: 670;"/>
                    
                    <!-- Login Link -->
                    <HBox alignment="CENTER" spacing="8" style="-fx-padding: 10 0 0 0;">
                        <Label text="Already have an account?" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
                        <Hyperlink text="Sign In" onAction="#backToLogin"
                                   style="-fx-font-size: 13px; -fx-text-fill: #2980B9; -fx-font-weight: bold; -fx-underline: true;"/>
                    </HBox>
                    
                </VBox>
                
                <!-- Info Cards -->
                <HBox spacing="20" alignment="CENTER">
                    <VBox spacing="10" alignment="CENTER" 
                          style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-pref-width: 235;">
                        <effect><DropShadow color="#00000015" radius="10" offsetY="3"/></effect>
                        <Label text="🚀" style="-fx-font-size: 32px;"/>
                        <Label text="Quick Setup" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                        <Label text="Get started in under 2 minutes" 
                               style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" wrapText="true" alignment="CENTER"/>
                    </VBox>
                    
                    <VBox spacing="10" alignment="CENTER"
                          style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-pref-width: 235;">
                        <effect><DropShadow color="#00000015" radius="10" offsetY="3"/></effect>
                        <Label text="🔒" style="-fx-font-size: 32px;"/>
                        <Label text="Secure Platform" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                        <Label text="Your data is encrypted and protected" 
                               style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" wrapText="true" alignment="CENTER"/>
                    </VBox>
                    
                    <VBox spacing="10" alignment="CENTER"
                          style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-pref-width: 235;">
                        <effect><DropShadow color="#00000015" radius="10" offsetY="3"/></effect>
                        <Label text="🎯" style="-fx-font-size: 32px;"/>
                        <Label text="Multi-Role Support" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                        <Label text="Register as any role in the system" 
                               style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" wrapText="true" alignment="CENTER"/>
                    </VBox>
                </HBox>
                
            </VBox>
        </ScrollPane>
    </center>
    
</BorderPane>