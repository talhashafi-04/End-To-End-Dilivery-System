<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.effect.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="application.LoginController"
            prefWidth="1400" prefHeight="850"
            style="-fx-background-color: #f5f5f5;">
    
    <left>
        <!-- Brand Panel -->
        <VBox style="-fx-background-color: linear-gradient(to bottom, #2980B9, #2C3E50); -fx-pref-width: 550;">
            <padding><Insets top="50" right="40" bottom="50" left="40"/></padding>
            
            <!-- Logo & Title -->
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label text="📦" style="-fx-font-size: 56px;"/>
                <VBox>
                    <Label text="SwiftShip" style="-fx-text-fill: white; -fx-font-size: 42px; -fx-font-weight: bold; -fx-font-family: 'Century Gothic';"/>
                    <Label text="Enterprise Delivery Management" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 14px;"/>
                </VBox>
            </HBox>
            
            <Region VBox.vgrow="SOMETIMES" minHeight="30"/>
            
            <!-- System Stats -->
            <Label text="System Overview" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold; -fx-padding: 0 0 20 0;"/>
            
            <GridPane hgap="15" vgap="15">
                <columnConstraints>
                    <ColumnConstraints percentWidth="33"/>
                    <ColumnConstraints percentWidth="33"/>
                    <ColumnConstraints percentWidth="34"/>
                </columnConstraints>
                
                <!-- Stat Card 1 -->
                <VBox GridPane.columnIndex="0" alignment="CENTER" spacing="8" 
                      style="-fx-background-color: rgba(46, 204, 113, 0.2); -fx-background-radius: 10; -fx-padding: 20;">
                    <Label text="✓" style="-fx-text-fill: #2ECC71; -fx-font-size: 28px;"/>
                    <Label text="12,847" style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                    <Label text="Delivered" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12px;"/>
                </VBox>
                
                <!-- Stat Card 2 -->
                <VBox GridPane.columnIndex="1" alignment="CENTER" spacing="8"
                      style="-fx-background-color: rgba(255, 152, 0, 0.2); -fx-background-radius: 10; -fx-padding: 20;">
                    <Label text="🚛" style="-fx-font-size: 28px;"/>
                    <Label text="384" style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                    <Label text="In Transit" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12px;"/>
                </VBox>
                
                <!-- Stat Card 3 -->
                <VBox GridPane.columnIndex="2" alignment="CENTER" spacing="8"
                      style="-fx-background-color: rgba(52, 152, 219, 0.2); -fx-background-radius: 10; -fx-padding: 20;">
                    <Label text="👥" style="-fx-font-size: 28px;"/>
                    <Label text="2,156" style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                    <Label text="Active Users" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12px;"/>
                </VBox>
            </GridPane>
            
            <Region VBox.vgrow="SOMETIMES" minHeight="30"/>
            
            <!-- Features List -->
            <VBox spacing="20">
                <Label text="Platform Features" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="🎯" style="-fx-font-size: 24px;"/>
                    <VBox spacing="3">
                        <Label text="Multi-Role Access" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Label text="Customer, Manager, Dispatcher, Riders, Warehouse" 
                               style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 11px;" wrapText="true"/>
                    </VBox>
                </HBox>
                
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="📊" style="-fx-font-size: 24px;"/>
                    <VBox spacing="3">
                        <Label text="Real-Time Analytics" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Label text="Live tracking, status updates, performance metrics" 
                               style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 11px;" wrapText="true"/>
                    </VBox>
                </HBox>
                
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="🔔" style="-fx-font-size: 24px;"/>
                    <VBox spacing="3">
                        <Label text="Smart Notifications" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Label text="Instant alerts for order updates and assignments" 
                               style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 11px;" wrapText="true"/>
                    </VBox>
                </HBox>
                
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="🔒" style="-fx-font-size: 24px;"/>
                    <VBox spacing="3">
                        <Label text="Secure &amp; Reliable" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Label text="Encrypted data, audit trails, role-based permissions" 
                               style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 11px;" wrapText="true"/>
                    </VBox>
                </HBox>
            </VBox>
            
            <Region VBox.vgrow="ALWAYS"/>
            
            <!-- Footer Info -->
            <HBox spacing="20" style="-fx-padding: 20 0 0 0;">
                <Label text="© 2025 SwiftShip" style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 11px;"/>
                <Label text="•" style="-fx-text-fill: rgba(255,255,255,0.6);"/>
                <Label text="Version 2.0" style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 11px;"/>
            </HBox>
        </VBox>
    </left>
    
    <center>
        <!-- Login Form Panel -->
        <VBox alignment="CENTER" spacing="0" style="-fx-background-color: white;">
            <padding><Insets top="60" right="80" bottom="60" left="80"/></padding>
            
            <VBox spacing="30" style="-fx-pref-width: 500;">
                
                <!-- Header -->
                <VBox spacing="10" alignment="CENTER">
                    <Label text="Welcome Back!" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2C3E50; -fx-font-family: 'Century Gothic';"/>
                    <Label text="Sign in to access your dashboard" style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
                </VBox>
                
                <Separator style="-fx-background-color: #ecf0f1;"/>
                
                <!-- Role Selection -->
                <VBox spacing="10">
                    <Label text="Select Your Role *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                    <ComboBox fx:id="roleComboBox" prefWidth="500" prefHeight="45"
                              style="-fx-font-size: 14px; -fx-background-radius: 8; -fx-border-color: #dce0e3; -fx-border-radius: 8; -fx-border-width: 2;">
                        <tooltip><Tooltip text="Choose your account type"/></tooltip>
                    </ComboBox>
                </VBox>
                
                <!-- Username Field -->
                <VBox spacing="10">
                    <Label text="Username *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                    <HBox alignment="CENTER_LEFT" spacing="12" 
                          style="-fx-background-color: #f8f9fa; -fx-background-radius: 8; -fx-padding: 12 15; -fx-border-color: #dce0e3; -fx-border-radius: 8; -fx-border-width: 2;">
                        <Label text="👤" style="-fx-font-size: 20px;"/>
                        <TextField fx:id="usernameField" promptText="Enter your username" 
                                   style="-fx-background-color: transparent; -fx-border-width: 0; -fx-font-size: 14px; -fx-pref-width: 430;"/>
                    </HBox>
                </VBox>
                
                <!-- Password Field -->
                <VBox spacing="10">
                    <Label text="Password *" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                    <HBox alignment="CENTER_LEFT" spacing="12"
                          style="-fx-background-color: #f8f9fa; -fx-background-radius: 8; -fx-padding: 12 15; -fx-border-color: #dce0e3; -fx-border-radius: 8; -fx-border-width: 2;">
                        <Label text="🔒" style="-fx-font-size: 20px;"/>
                        <PasswordField fx:id="passwordField" promptText="Enter your password"
                                       style="-fx-background-color: transparent; -fx-border-width: 0; -fx-font-size: 14px; -fx-pref-width: 430;"/>
                    </HBox>
                </VBox>
                
                <!-- Remember & Forgot -->
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <CheckBox fx:id="rememberMeCheckbox" text="Remember me" 
                              style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Hyperlink text="Forgot Password?" onAction="#handleForgotPassword"
                               style="-fx-font-size: 12px; -fx-text-fill: #2980B9; -fx-underline: true;"/>
                </HBox>
                
                <!-- Login Button -->
                <Button text="Sign In" onAction="#handleLogin" prefHeight="50"
                        style="-fx-background-color: #2980B9; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-pref-width: 500;">
                    <effect><DropShadow color="#2980B980" radius="10" offsetY="3"/></effect>
                </Button>
                
                <!-- Status Label -->
                <Label fx:id="statusLabel" alignment="CENTER" wrapText="true"
                       style="-fx-font-size: 13px; -fx-padding: 10; -fx-background-radius: 5; -fx-pref-width: 500;"/>
                
                <!-- Signup Link -->
                <HBox alignment="CENTER" spacing="8">
                    <Label text="Don't have an account?" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
                    <Hyperlink text="Create Account" onAction="#showSignup"
                               style="-fx-font-size: 13px; -fx-text-fill: #2980B9; -fx-font-weight: bold; -fx-underline: true;"/>
                </HBox>
                
                <Separator style="-fx-background-color: #ecf0f1; -fx-padding: 10 0 0 0;"/>
                
                <!-- Quick Test Credentials -->
                <VBox spacing="15" style="-fx-background-color: #f8f9fa; -fx-background-radius: 10; -fx-padding: 20;">
                    <Label text="🧪 Test Credentials" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                    
                    <GridPane hgap="15" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="35"/>
                            <ColumnConstraints percentWidth="65"/>
                        </columnConstraints>
                        
                        <Label text="Customer:" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #555;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <Label text="john_doe / password123" style="-fx-font-size: 11px; -fx-text-fill: #2980B9; -fx-font-family: 'Courier New';" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        
                        <Label text="Manager:" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #555;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <Label text="manager / manager123" style="-fx-font-size: 11px; -fx-text-fill: #2980B9; -fx-font-family: 'Courier New';" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        
                        <Label text="Dispatcher:" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #555;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <Label text="dispatcher / disp123" style="-fx-font-size: 11px; -fx-text-fill: #2980B9; -fx-font-family: 'Courier New';" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                        
                        <Label text="Pickup Rider:" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #555;" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <Label text="pickup_rider / rider123" style="-fx-font-size: 11px; -fx-text-fill: #2980B9; -fx-font-family: 'Courier New';" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                        
                        <Label text="Delivery Rider:" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #555;" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                        <Label text="delivery_rider / delivery123" style="-fx-font-size: 11px; -fx-text-fill: #2980B9; -fx-font-family: 'Courier New';" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                        
                        <Label text="Warehouse:" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #555;" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                        <Label text="warehouse / warehouse123" style="-fx-font-size: 11px; -fx-text-fill: #2980B9; -fx-font-family: 'Courier New';" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                    </GridPane>
                </VBox>
                
            </VBox>
        </VBox>
    </center>
    
</BorderPane>